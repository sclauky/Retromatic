<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="backend.sudoku.SudokuController"
            stylesheets="@sudoku.css"
            styleClass="root-memory">

    <!-- HAUT -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="sudoku-header" spacing="20">
            <Label text="SUDOKU" styleClass="sudoku-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="scoreLabel" text="SCORE: 0" styleClass="score-label"/>
            <ComboBox fx:id="difficultyCombo"
                      onAction="#handleDifficultyChange"
                      promptText="Difficulté"
                      styleClass="difficulty-select"/>
            <Button text="Accueil"
                    onAction="#handleBack"
                    styleClass="game-button"/>
        </HBox>
    </top>

    <!-- CENTRE -->
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 20 40 10 40;">
            <Label text="Clique sur une case puis tape un chiffre (1-9)"
                   styleClass="sudoku-subtitle"/>
            <GridPane fx:id="sudokuGrid"
                      alignment="CENTER"
                      hgap="0" vgap="0"/>
            <Label fx:id="statusLabel"
                   text=""
                   style="-fx-font-size: 20px; -fx-font-family: 'Impact', sans-serif; -fx-text-fill: #7ECFB3; -fx-letter-spacing: 4px; -fx-effect: dropshadow(gaussian, #7ECFB3, 10, 0.3, 0, 0);"/>
        </VBox>
    </center>

    <!-- BAS -->
    <bottom>
        <HBox alignment="CENTER" styleClass="sudoku-footer" spacing="0">
            <Button text="RESET"
                    onAction="#handleRestart"
                    styleClass="btn-restart"/>
        </HBox>
    </bottom>

</BorderPane>