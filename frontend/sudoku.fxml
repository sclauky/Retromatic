<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="backend.sudoku.SudokuController"
            stylesheets="@sudoku.css"
            style="-fx-background-color: #0d0d1a;">

    <!-- HAUT -->
    <top>
        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 20 0 10 0;">
            <Label text="✦ SUDOKU SPATIAL ✦"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #7ECFB3;"/>
            <Label text="Clique sur une case puis tape un chiffre (1-9)"
                   style="-fx-font-size: 13px; -fx-text-fill: #8888aa;"/>
        </VBox>
    </top>

    <!-- CENTRE -->
    <center>
        <VBox alignment="CENTER" spacing="20">
            <GridPane fx:id="sudokuGrid"
                      alignment="CENTER"
                      hgap="0" vgap="0"/>
            <Label fx:id="statusLabel"
                   text=""
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>
    </center>

    <!-- BAS -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 20;">
            <Button text="🔄 NOUVELLE PARTIE"
                    onAction="#handleRestart"
                    styleClass="game-button"/>
            <Button text="🏠 ACCUEIL"
                    onAction="#handleBack"
                    styleClass="game-button"/>
        </HBox>
    </bottom>

</BorderPane>